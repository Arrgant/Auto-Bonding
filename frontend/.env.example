# Auto-Bonding Frontend Configuration

# API 基础 URL
# 开发环境：/api (通过 Vite 代理到后端)
# 生产环境：完整的后端地址，如 https://api.auto-bonding.com
VITE_API_BASE_URL=/api

# 应用标题
VITE_APP_TITLE=Auto-Bonding

# 应用版本
VITE_APP_VERSION=0.2.0

# 最大文件上传大小 (MB)
VITE_MAX_FILE_SIZE=50

# 允许的文件类型
VITE_ALLOWED_FILE_TYPES=.dxf

# 启用/禁用功能
VITE_ENABLE_DRC=true
VITE_ENABLE_BATCH=true
VITE_ENABLE_3D_PREVIEW=true
