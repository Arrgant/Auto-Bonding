# Auto-Bonding Backend Configuration

# ===== 安全配置 =====

# CORS 允许的来源（逗号分隔）
# 生产环境应改为具体域名，如：https://auto-bonding.com,https://www.auto-bonding.com
ALLOWED_ORIGINS=*

# 是否允许携带凭证（cookies）
ALLOW_CREDENTIALS=true

# 允许的 HTTP 方法
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# 允许的请求头
ALLOWED_HEADERS=Content-Type,Authorization

# ===== 文件配置 =====

# 临时文件保留时间（秒），默认 1 小时
FILE_RETENTION_SECONDS=3600

# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE=50

# 临时文件目录（可选，默认使用系统临时目录）
# TEMP_DIR=/tmp/auto-bonding

# ===== 服务配置 =====

# 服务端口
PORT=8000

# 服务主机
HOST=0.0.0.0

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
